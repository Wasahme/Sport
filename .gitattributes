# Auto detect text files and perform LF normalization
* text=auto

# Kotlin files
*.kt text eol=lf
*.kts text eol=lf

# Java files
*.java text eol=lf

# XML files
*.xml text eol=lf

# Gradle files
*.gradle text eol=lf
*.gradle.kts text eol=lf

# Properties files
*.properties text eol=lf

# Markdown files
*.md text eol=lf

# Documentation
*.txt text eol=lf
*.rst text eol=lf

# Graphics
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# Archives
*.7z binary
*.bz2 binary
*.gz binary
*.rar binary
*.tar binary
*.zip binary

# Executables
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# APK files
*.apk binary
*.aab binary

# Keystore files
*.jks binary
*.keystore binary

# Logs
*.log text eol=lf

# IDE files
.idea/ text eol=lf
.vscode/ text eol=lf

# OS generated files
.DS_Store binary
Thumbs.db binary