<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include database files -->
        <include domain="database" path="." />
        
        <!-- Include shared preferences -->
        <include domain="sharedpref" path="." />
        
        <!-- Include files in external files directory -->
        <include domain="external" path="." />
        
        <!-- Exclude sensitive files -->
        <exclude domain="database" path="sensitive_data.db" />
        <exclude domain="sharedpref" path="sensitive_prefs.xml" />
        
        <!-- Exclude cache files -->
        <exclude domain="external" path="cache" />
        <exclude domain="cache" path="." />
    </cloud-backup>
    
    <device-transfer>
        <!-- Include database files -->
        <include domain="database" path="." />
        
        <!-- Include shared preferences -->
        <include domain="sharedpref" path="." />
        
        <!-- Include files in external files directory -->
        <include domain="external" path="." />
        
        <!-- Exclude sensitive files -->
        <exclude domain="database" path="sensitive_data.db" />
        <exclude domain="sharedpref" path="sensitive_prefs.xml" />
        
        <!-- Exclude cache files -->
        <exclude domain="external" path="cache" />
        <exclude domain="cache" path="." />
    </device-transfer>
</data-extraction-rules>