<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="sensitive_data.xml"/>
        <exclude domain="database" path="sensitive_database.db"/>
        <exclude domain="file" path="private_files/"/>
    </cloud-backup>
    
    <device-transfer>
        <!-- Allow device transfer for most data -->
        <include domain="database" path="fittracker_db"/>
        <include domain="sharedpref" path="user_preferences.xml"/>
        <exclude domain="sharedpref" path="sensitive_data.xml"/>
    </device-transfer>
</data-extraction-rules>